          "layoutInverted": false,
          "phoneButtonMarginTopPx": 32,
          "phoneButtonVisible": true,
          "contentEyebrow": "Spartan Restoration",
          "contentImageSrc": "/spartan/library/Store.jpg",
          "contentImageAlt": "Store",
          "contentHeadlineLines": [
            "24/7 Emergency Restoration",
            "You Can Count On Water,",
            "Storm, Mold & Sewage Damage"
          ],
          "contentBody": "Disasters don't wait for business hours and neither do we. Spartan Restoration is a locally trusted emergency restoration company serving Vancouver and the Pacific Northwest. Our crews bring clear communication, steady leadership, and hands-on experience to every job, from the first call through final walkthrough."
        }
      },
      "content-de5e3eab": {
        "textImage": {
          "theme": "light",
          "backgroundColor": "#ffffff",
          "eyebrowColor": "#56616A",
